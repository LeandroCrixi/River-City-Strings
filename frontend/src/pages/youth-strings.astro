  <!-- PROGRAMS REQUIREMETNS SECTION -->
  <section class="services programs-req">
    <div class="title">
      <h3>Our Semester <br /> <span class="italic">Plan</span></h3>
      <p class="arrow">
        <img src="/arrow.svg" alt="" />
        <!-- <Image src={arrow} alt="" /> -->
      </p>
    </div>
    <div class="card-container">
      {
        programsReq.map((program: any) => (
          <div class="service-card">
            <div class="service-content">
              <h4>{program.title}</h4>
              <ul>
                {program.req.map((item: any) => (
                  <li>{item.req}</li>
                ))}
              </ul>
              <p>{program.details}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="extra-info container">
    <h4>Program Experience</h4>
    <p>
      River City Youth Strings provides a positive first orchestra experience where students learn collaboration,
      responsibility, and musical expression.
    </p>

---
import BaseLayout from '../layouts/MainLayout.astro'
import { sanityClient } from 'sanity:client'
import { createImageUrlBuilder } from '@sanity/image-url'
import { Image } from 'astro:assets'
import heroImg from '../../src/assets/images/home/bg-img.jpg'
import arrow from '../../src/assets/icons/arrow.svg'
import check from '../../src/assets/icons/check.svg'
import clock from '../../src/assets/icons/clock.svg'

// Fetch the Home Page data
const homeData = await sanityClient.fetch(`*[_type == "youthStringsPage"][0]`)

// If no data exists yet, we provide fallbacks so the site doesn't crash
const {
  heroTitle = 'Inspiring Musicians.',
  heroSubtitle = 'Building Confidence. Creating Community.',
  welcomeTitle = '',
  welcomeText = '',
  welcomeImage = '',
  featuresPrice = [],
  tuitionPrice = '',
  featuresTitle = '',
  priceTitle = '',
  priceText = '',
  features = [],

  programsReq = [],
} = homeData || {}

// Build Sanity image URL if welcomeImage exists
const builder = createImageUrlBuilder(sanityClient)
// Helper function to make the HTML cleaner
function urlFor(source: any) {
  return builder.image(source)
}
const welcomeImageUrl = welcomeImage && welcomeImage.asset ? builder.image(welcomeImage).url() : ''
---

<BaseLayout title="Youth Strings Page">
  <section class="youth-hero page-hero hero">
    <div class="hero-content">
      <h1>{heroTitle}</h1>
      <p>{heroSubtitle}</p>
    </div>
    <!-- <img src="../../src/assets/images/home/bg-img.jpg" alt="" /> -->
    <Image src={heroImg} alt="" />
  </section>

  <section class="youth-welcome welcome container">
    <div class="welcome-content">
      <h3>
        {welcomeTitle.split('\n')[0]}<br />
        <i>{welcomeTitle.split('\n')[1]}</i>
      </h3>
      <p set:html={welcomeText.replace(/\n/g, '<br />')} />
    </div>
    <div class="welcome-img">
      {welcomeImageUrl && <img src={welcomeImageUrl} alt="Welcome" />}
    </div>
  </section>

  <!-- PROGRAMS REQUIREMETNS SECTION -->
  <section class="services programs-req">
    <div class="title">
      <!-- <h3>Our Semester <br /> <span class="italic">Plan</span></h3> -->
      <h3>Our Semester Plan<br /> <span class="italic">$ {tuitionPrice} / Semester</span></h3>
      <!-- <h2>$ {tuitionPrice} / Semester</h2> -->
      <p class="arrow">
        <!-- <Image src={arrow} alt="" /> -->
      </p>
    </div>
    <div class="card-container">
      {
        programsReq.map((program: any) => (
          <div class="service-card">
            <div class="service-content">
              <h4>{program.title}</h4>
              <ul>
                {program.req.map((item: any) => (
                  <li>{item.req}</li>
                ))}
              </ul>
              <p>{program.details}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- <section class="lessons-welcome welcome container">
    <div class="welcome-price">
      <h4>{priceTitle}</h4>
      <p>{priceText}</p>
      <ul>
        {
          featuresPrice.map((features: any) => (
            <li>
              <span>
                <Image src={clock} alt="" /> {features.priceMinutes + ' minutes'}
              </span>{' '}
              <span>{'$' + features.price}</span>
            </li>
          ))
        }
      </ul>
      <p>Per session pricing. Lessons are scheduled weekly.</p>
      <button class="btn">Register for Lessons</button>
      <br />
      <span>Or call (616) 822-6252</span>
    </div>
    <div class="welcome-content">
      <h3>
        {welcomeTitle.split('\n')[0]}<br />
        <i>{welcomeTitle.split('\n')[1]}</i>
      </h3>
      <p set:html={welcomeText.replace(/\n/g, '<br />')} />

      <h4>{featuresTitle}</h4>
      <ul>
        {
          features.map((feature: any) => (
            <li>
              <Image src={check} alt="" />
              {feature.description}
            </li>
          ))
        }
      </ul>
    </div>
  </section> -->

  <section class="extra-info container">
    <h4>Program Experience</h4>
    <p>
      River City Youth Strings provides a positive first orchestra experience where students learn collaboration,
      responsibility, and musical expression.
    </p>
    <p>
      Rehearsals are structured yet encouraging, allowing students to grow at their own pace while feeling part of a
      musical community.
    </p>
  </section>
</BaseLayout>

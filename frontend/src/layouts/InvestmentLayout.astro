---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Raleway:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />

    <meta
      property="og:title"
      content="River City Strings | Violin & Viola Lessons"
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:description"
      content="Professional strings lessons, chamber music coaching, and event musicians in Cascade Township."
    />

    <link rel="stylesheet" href="../../src/style/style.css" />

    <script is:inline>
      document.documentElement.classList.add('js')
    </script>
    <title>{title} | River City Strings</title>
  </head>

  <body>
    <Header />

    <main>
      <div class="investmentSection">
        <slot />
      </div>
    </main>

    <Footer />

    <script src="/src/scripts/script.js"></script>
  </body>
</html>
